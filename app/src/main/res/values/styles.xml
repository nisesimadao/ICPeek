<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- Apple HIG inspired theme -->
    <style name="Theme.ICPeek" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/system_blue</item>
        <item name="colorPrimaryVariant">@color/system_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/system_gray</item>
        <item name="colorSecondaryVariant">@color/system_gray2</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/system_background</item>
        <item name="colorSurface">@color/secondary_system_background</item>
        <item name="colorOnBackground">@color/label</item>
        <item name="colorOnSurface">@color/label</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/system_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor" tools:targetApi="l">@color/system_background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        
        <!-- Remove window decor -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <!-- Typography Styles -->
    <style name="TextAppearance.ICPeek.LargeTitle" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textSize">@dimen/text_size_large_title</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Title1" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textSize">@dimen/text_size_title_1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.21</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Title2" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">@dimen/text_size_title_2</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.27</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Title3" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">@dimen/text_size_title_3</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.25</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">@dimen/text_size_headline</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.29</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.29</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Callout" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">@dimen/text_size_callout</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.31</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Subhead" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">@dimen/text_size_subhead</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.33</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Footnote" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/text_size_footnote</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/secondary_label</item>
        <item name="android:lineSpacingMultiplier">1.38</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Caption1" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textSize">@dimen/text_size_caption_1</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/tertiary_label</item>
        <item name="android:lineSpacingMultiplier">1.33</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Caption2" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textSize">@dimen/text_size_caption_2</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/tertiary_label</item>
        <item name="android:lineSpacingMultiplier">1.36</item>
    </style>
    
    <!-- Component Styles -->
    <style name="Widget.ICPeek.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="android:paddingLeft">@dimen/spacing_lg</item>
        <item name="android:paddingRight">@dimen/spacing_lg</item>
    </style>

    <style name="Widget.ICPeek.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:minHeight">@dimen/button_height_md</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="android:paddingLeft">@dimen/spacing_lg</item>
        <item name="android:paddingRight">@dimen/spacing_lg</item>
    </style>

    <style name="Widget.ICPeek.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/corner_radius_md</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
        <item name="cardBackgroundColor">@color/secondary_system_background</item>
        <item name="android:layout_margin">@dimen/card_spacing</item>
    </style>
    
    <!-- Balance Display Styles -->
    <style name="TextAppearance.ICPeek.Balance.Large" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textSize">48sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.0</item>
    </style>
    
    <style name="TextAppearance.ICPeek.Balance.Medium" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textColor">@color/label</item>
        <item name="android:lineSpacingMultiplier">1.0</item>
    </style>
    
    <!-- Card Type Badge Styles -->
    <style name="Widget.ICPeek.CardTypeBadge" parent="Widget.AppCompat.TextView">
        <item name="android:background">@drawable/card_type_badge_background</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:paddingStart">@dimen/spacing_sm</item>
        <item name="android:paddingEnd">@dimen/spacing_sm</item>
        <item name="android:paddingTop">@dimen/spacing_xs</item>
        <item name="android:paddingBottom">@dimen/spacing_xs</item>
    </style>
    
</resources>
