<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/card_spacing"
    app:cardCornerRadius="@dimen/corner_radius_md"
    app:cardElevation="@dimen/elevation_sm"
    app:cardBackgroundColor="@color/system_background"
    app:strokeWidth="@dimen/stroke_width_thin"
    app:strokeColor="@color/separator"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_sm">

            <TextView
                android:id="@+id/transactionDateTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2025/11/29"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/label" />

            <TextView
                android:id="@+id/transactionAmountChangeTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+¥100"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/system_green"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/amount_change_background"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs" />

            <TextView
                android:id="@+id/transactionBalanceTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥831"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/system_blue"
                android:layout_marginStart="@dimen/spacing_sm" />

        </LinearLayout>

        <!-- Transaction Type -->
        <TextView
            android:id="@+id/transactionTypeTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="物販: 物販端末"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/secondary_label"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Transaction Details -->
        <TextView
            android:id="@+id/transactionDetailsTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="残高: ¥831 | 連番: 2293760"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/tertiary_label"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
